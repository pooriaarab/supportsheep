{
  "name": "supportsheep",
  "version": "0.1.0",
  "description": "Blog platform for supportsheep.com — Next.js/Firebase/Netlify",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash bin/dev-worktree.sh",
    "dev:next": "turbo run dev --filter=@repo/web",
    "build": "turbo run build --filter=!@repo/desktop",
    "start": "cd apps/web && bun run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "cd apps/web && bunx playwright test",
    "prepare": "husky"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --config apps/web/eslint.config.mjs --fix"
    ]
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "turbo": "^2.8.15"
  },
  "overrides": {
    "prosemirror-model": "1.25.7",
    "prosemirror-state": "1.4.4",
    "prosemirror-view": "1.41.8",
    "prosemirror-transform": "1.12.0",
    "prosemirror-commands": "1.7.1",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-schema-list": "1.5.1",
    "prosemirror-tables": "1.8.5",
    "prosemirror-history": "1.5.0",
    "prosemirror-dropcursor": "1.8.2",
    "prosemirror-gapcursor": "1.4.1",
    "prosemirror-changeset": "2.4.1"
  },
  "resolutions": {
    "prosemirror-model": "1.25.7",
    "prosemirror-state": "1.4.4",
    "prosemirror-view": "1.41.8",
    "prosemirror-transform": "1.12.0",
    "prosemirror-commands": "1.7.1",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-schema-list": "1.5.1",
    "prosemirror-tables": "1.8.5",
    "prosemirror-history": "1.5.0",
    "prosemirror-dropcursor": "1.8.2",
    "prosemirror-gapcursor": "1.4.1",
    "prosemirror-changeset": "2.4.1"
  }
}
