# ========================
# App Configuration
# ========================
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_ENVIRONMENT=dev

# ========================
# Firebase Client SDK (public, exposed to browser)
# ========================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ========================
# Firebase Admin SDK (server-only, never exposed to browser)
# ========================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ========================
# Firebase Storage
# ========================
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app

# ========================
# AI / LLM (users configure in /admin/settings/ai, these are dev overrides)
# ========================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
INTERVIEW_TOKEN_SECRET= # 32+ random bytes hex (used to sign interview tokens)
GOOGLE_GENERATIVE_AI_API_KEY=

# ========================
# Optional: Analytics & Monitoring
# ========================
# SENTRY_DSN=
# NEXT_PUBLIC_GA_ID=
# MS_CLARITY_PROJECT_ID=

# ========================
# Google Search Console / GA4 OAuth
# ========================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://blogbat.com/
GOOGLE_ANALYTICS_MEASUREMENT_ID=
GOOGLE_ANALYTICS_PROPERTY_ID=

# ========================
# Optional: Hosting
# ========================
# NETLIFY_SITE_ID=

# ========================
# Auth allowlists (env-driven, empty = permissive defaults)
# ========================
# Comma-separated allowlist of emails permitted to use the gated dev-login endpoint.
# Leave empty in production unless actively debugging.
DEV_LOGIN_ALLOWLIST=
# Optional comma-separated allowlist of email domains permitted to authenticate
# (e.g. "@example.com"). Empty = all domains allowed.
ALLOWED_EMAIL_DOMAINS=

# ========================
# Better Auth (M2 migration — stood up alongside Firebase Auth, not yet cut over)
# ========================
# Strong random secret (e.g. `openssl rand -base64 32`). Set as a deploy secret in CI.
BETTER_AUTH_SECRET=
# Public base URL Better Auth issues links against (e.g. https://staging.blogbat.com).
BETTER_AUTH_URL=
# Magic-link sender address (sent via Cloudflare Email Service once that's wired).
AUTH_EMAIL_FROM=auth@blogbat.com
